{
  "name": "@agentensemble/viz",
  "version": "0.1.0",
  "description": "Trace viewer and execution graph visualizer for AgentEnsemble",
  "type": "module",
  "main": "./cli.js",
  "bin": {
    "agentensemble-viz": "./cli.js"
  },
  "files": [
    "dist",
    "cli.js",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "compile:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 cli.js --outfile agentensemble-viz",
    "compile:darwin-x64": "bun build --compile --target=bun-darwin-x64 cli.js --outfile agentensemble-viz",
    "compile:linux-x64": "bun build --compile --target=bun-linux-x64 cli.js --outfile agentensemble-viz"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.0.4",
    "@xyflow/react": "^12.5.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.12.7",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.5.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "keywords": [
    "agentensemble",
    "agent",
    "ai",
    "llm",
    "visualization",
    "trace",
    "debugger"
  ],
  "license": "MIT",
  "homepage": "https://github.com/AgentEnsemble/agentensemble",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentEnsemble/agentensemble.git"
  }
}

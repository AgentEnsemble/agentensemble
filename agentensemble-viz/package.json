{
  "name": "@agentensemble/viz",
  "version": "0.1.0",
  "description": "Trace viewer and execution graph visualizer for AgentEnsemble",
  "type": "module",
  "main": "./cli.js",
  "bin": {
    "agentensemble-viz": "./cli.js"
  },
  "files": [
    "dist",
    "cli.js",
    "dist-assets.js",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "embed": "node scripts/embed-dist.mjs",
    "check:assets": "node scripts/check-assets.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run embed",
    "compile:darwin-arm64": "npm run build && npm run embed && bun build --compile --target=bun-darwin-arm64 cli.js --outfile agentensemble-viz",
    "compile:darwin-x64": "npm run build && npm run embed && bun build --compile --target=bun-darwin-x64 cli.js --outfile agentensemble-viz",
    "compile:linux-x64": "npm run build && npm run embed && bun build --compile --target=bun-linux-x64 cli.js --outfile agentensemble-viz"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@xyflow/react": "^12.10.2",
    "react-resizable-panels": "^4.10.0",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.4.5",
    "vite": "^7.3.1",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "keywords": [
    "agentensemble",
    "agent",
    "ai",
    "llm",
    "visualization",
    "trace",
    "debugger"
  ],
  "license": "MIT",
  "homepage": "https://github.com/AgentEnsemble/agentensemble",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentEnsemble/agentensemble.git"
  }
}
